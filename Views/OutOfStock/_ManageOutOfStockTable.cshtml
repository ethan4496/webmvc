@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<ManageOutOfStockResponse>


<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center"></th>
                    <th class="text-center">Mã phiếu</th>
                    <th class="text-center">Username</th>
                    <th class="text-center">Mã vận đơn</th>
                    <th class="text-center">Thông tin</th>
                    <th class="text-center">Bưu cục</th>
                    <th class="text-center">HT giao hàng </th>
                    <th class="text-center">TT nhận hàng </th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr out-stock-id="@Model[i].Id" style="--bs-table-bg:@Model[i].LineColor">
                        <td class="text-center"><input type="checkbox" class="waybillCheckbox" /></td>
                        <td class="text-center">
                            @Model[i].Id

                            <p class="pt-2">@(@Model[i].DateOutStock != null ? $"Ngày XK: {Model[i].DateOutStock?.ToString("dd/MM/yyyy HH:mm")}" : "")</p>
                        </td>
                        <td class="text-center">@Model[i].Username</td>
                        <td class="text-center">
                            @if (Model[i].TransportationResponses.Count > 0)
                            {
                                <table class="table table-bordered">
                                    <thead class="table">
                                        <tr>
                                            <th class="text-center">Mã vận đơn</th>
                                            <th class="text-center">Số cân</th>
                                            <th class="text-center">Số khối</th>
                                            <th class="text-center"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model[i].TransportationResponses)
                                        {
                                            <tr @Html.Raw($"transportation-barcode-1-out-stock-id-{Model[i].Id}=\"{item.Barcode}\"")>
                                                <td rowspan="2">@item.Barcode</td>
                                                <td><input type="number" value="@item.Weight" min="0" class="form-control weight" /></td>
                                                <td><input type="number" value="@item.Volume" min="0" class="form-control volume" /></td>
                                                <td rowspan="2">
                                                    <button type="button" class="btn btn-sm btn-warning" onclick='updateTranportation(@Model[i].Id, "@item.Barcode.ToString()")'>
                                                        Cập nhật
                                                    </button>
                                                </td>
                                            </tr>
                                            <tr @Html.Raw($"transportation-barcode-2-out-stock-id-{Model[i].Id}=\"{item.Barcode}\"")>
                                                <td><input value="@item.UnitWeight" class="form-control input-money unitWeight" /></td>
                                                <td><input value="@item.UnitVolume" class="form-control input-money unitVolume" /></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </td>
                        <td class="text-center" style=" max-width: 250px; width: 250px; min-width: 250px; ">
                            @if (Model[i].TransportationResponses.Count > 0)
                            {
                                <p class="text-start">@Model[i].TransportationResponses?.Sum(x => x.Quantity ?? 1) kiện - @Math.Round((double)Model[i].TransportationResponses?.Sum(x => x.Weight ?? 0), 2) kg - @Model[i].TransportationResponses?.Sum(x => x.Volume ?? 0) m3</p>
                                <p class="text-start">PTVC: @Model[i].TransportationResponses.FirstOrDefault().ShipName</p>
                            }
                            <p class="d-flex align-items-center gap-3">
                                <span>
                                    Tổng tiền:
                                </span>
                                <input value="@Model[i].TotalPriceVND" class="form-control input-money totalPriceVND" />
                            </p>

                            <p class="pt-2">
                                <button class="btn btn-sm btn-warning" onclick="updateTotalPriceVND(@Model[i].Id)">Cập nhật</button>
                            </p>

                        </td>
                        <td class="text-center">
                            <select class="form-select postOffice" name="postOffice" onchange="updatePostOffice(@Model[i].Id)">
                                <option value="">
                                </option>
                                @foreach (var status in PostOfficeName.GetPostOffice())
                                {
                                    if (status == Model[i].PostOffice)
                                    {
                                        <option value="@status" selected>
                                            @status
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@status">
                                            @status
                                        </option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="text-center">
                            <select class="form-select deliveryMethod" name="deliveryMethod" onchange="updatedeliveryMethod(@Model[i].Id)">
                                <option value="">
                                </option>
                                @foreach (var status in DeliveryMethodName.GetDeliveryMethod())
                                {
                                    if (status == Model[i].DeliveryMethod)
                                    {
                                        <option value="@status" selected>
                                            @status
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@status">
                                            @status
                                        </option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="text-center">
                            <textarea class="form-control deliveryInfo" rows="5" style="width: 24rem !important;">@Model[i].DeliveryInfo</textarea>
                            <p class="pt-2">
                                <button class="btn btn-sm btn-warning" onclick="updateDeliveryInfo(@Model[i].Id)">Cập nhật</button>
                            </p>
                        </td>
                        <td class="text-center">
                            <p>@Html.Raw(Model[i].StatusPaymentName) @(Model[i].AccountPayment != null ? $"- {Model[i].AccountPayment}" : "") </p>
                            <p class="pt-2">@Html.Raw(Model[i].StatusName)</p>
                        </td>
                        <td class="text-center">
                            <p>
                                <button class="btn btn-sm btn-primary w-100" onclick="window.location.href='@Url.RouteUrl("out-of-stock-detail", new { id = Model[i].Id })'">
                                    Chi tiết
                                </button>
                            </p>
                            @if (Model[i].Status != (int)EOutOfStockStatus.Cancel)
                            {
                                @if (Model[i].IsRequest == true && Model[i].StatusPayment == (int)EPaymentOutOfStockStatus.New)
                                {
                                    <p><button class="btn btn-sm btn-purple w-100">Yêu cầu duyệt</button></p>
                                }
                                @if (Model[i].Status == (int)EOutOfStockStatus.New)
                                {
                                    <p><button class="btn btn-sm btn-success w-100" onclick="exportOutOfStock(@Model[i].Id)">In phiếu</button></p>
                                }
                                @if (Model[i].StatusPayment == (int)EPaymentOutOfStockStatus.New)
                                {
                                    <p><button class="btn btn-sm btn-success w-100" onclick="updatePaied(@Model[i].Id)">Đã thanh toán</button></p>
                                }
                                @if (Model[i].StatusPayment != (int)EOutOfStockStatus.Cancel)
                                {
                                    <p><button class="btn btn-sm btn-danger w-100" onclick="deleteOutOfStock(@Model[i].Id)">Hủy phiếu</button></p>
                                }
                                @if (Model[i].IsSend != true)
                                {
                                    <p><button class="btn btn-sm btn-secondary  w-100" onclick="sendDeliveryNote(@Model[i].Id)">Gửi phiếu</button></p>
                                }

                                <p><button class="btn btn-sm btn-secondary  w-100" onclick="printOutOfStockTemp(@Model[i].Id)">In phiếu tạm</button></p>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
<style>
    .text-center .form-select {
        width: unset !important;
    }

    .text-center .form-control {
        width: unset !important;
    }
</style>
<script>
    $('#txtTotalItem').text('Tổng số phiếu: ' + @ViewBag.TotalItem)
</script>