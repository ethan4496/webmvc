@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<AccountResponse>
<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center">Id</th>
                    <th class="text-center">Username</th>
                    <th class="text-center">NV Sale</th>
                    <th class="text-center">Họ và tên</th>
                    <th class="text-center">Số điện thoại</th>
                    <th class="text-center">Doanh số</th>
                    <th class="text-center">Phí riêng</th>
                    <th class="text-center">Ngày tạo</th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center align-content-center">@Model[i].Id</td>
                        <td class="text-center align-content-center">@Model[i].Username</td>
                        <td class="text-center align-content-center">@Model[i].SaleName</td>
                        <td class="text-center align-content-center">@Model[i].FullName</td>
                        <td class="text-center align-content-center">@Model[i].Phone</td>
                        <td class="text-center align-content-center">
                            @if (Model[i].AccountSalesResponses.Count > 0)
                            {
                                @await Html.PartialAsync("_SalesTableInList", Model[i].AccountSalesResponses)

                            }
                        </td>
                        <td class="text-center align-content-center">
                            @if (Model[i].PricingResponses.Count > 0)
                            {
                                @await Html.PartialAsync("_PricingSeparateTableInList", Model[i].PricingResponses)

                            }
                        </td>
                        <td class="text-center align-content-center">@Model[i].Created.ToString("dd/MM/yyyy")</td>
                        <td class="text-center align-content-center">
                            <p>
                                <button class="btn btn-sm btn-primary" onclick="window.location.href='@Url.RouteUrl("account-detail", new { id = Model[i].Id })'">
                                    Chi tiết
                                </button>
                            </p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
