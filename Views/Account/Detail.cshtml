@using WebMVC.Entities
@using WebMVC.Models.Responses
@using WebMVC.Interfaces
@using WebMVC.Ultilities.Enums
@inject IHttpContextService _httpContextService;
@{
    var loggedModel = _httpContextService.GetLoggedModel();
}
@{
    ViewData["Title"] = "Chi tiết tài khoản";
}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-annotation/1.0.2/chartjs-plugin-annotation.min.js"></script>
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-5">
            <div class="card mb-6">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2>Chi tiết tài khoản</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="text-center">
                            <a href="@Model.Account.Avatar" target="_blank" class="avatar-wrapper" id="avatarContainer">
                                <img id="avatar" src="@Model.Account.Avatar" alt="">
                                <label for="uploadAvatar"><i class="bi bi-eye"></i></label>
                            </a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <label for="Username" class="form-label">Username</label>
                            <input value="@Model.Account.Username" readonly type="text" class="form-control" id="username" name="Username" placeholder="">
                        </div>
                        <div class="col-md-6">
                            <label for="fullName" class="form-label">Họ và tên</label>
                            <input value="@Model.Account.FullName" required type="text" class="form-control" id="fullName" placeholder="Họ và tên">
                        </div>
                    </div>
                    <div class="row pt-2">
                        <div class="col-md-6">
                            <label for="email" class="form-label">Email</label>
                            <input value="@Model.Account.Email" required type="email" class="form-control" id="email" placeholder="Email">
                        </div>
                        <div class="col-md-6">
                            <label for="phone" class="form-label">Số điện thoại</label>
                            <input value="@Model.Account.Phone" required type="text" class="form-control" id="phone" placeholder="Số điện thoại" pattern="(0[2-9]|84[2-9])[0-9]{8}" title="Số điện thoại phải có 10 số và bắt đầu bằng 0 hoặc 84">
                        </div>
                    </div>
                    <div class="row pt-2">
                        <div class="col-md-6">
                            <label for="address" class="form-label">Địa chỉ</label>
                            <input value="@Model.Account.Address" required type="text" class="form-control" id="address" placeholder="Địa chỉ">
                        </div>
                        <div class="col-md-6">

                            <label for="sale" class="form-label">NV Sale</label>
                            <select id="sale" class="form-select" name="sale">
                                @if (loggedModel.RoleId == (int)ERoleId.Sale)
                                {
                                    @foreach (var sale in Model.ListSale)
                                    {
                                        if (sale.Id == loggedModel.RoleId)
                                        {
                                            <option value="@sale.Id" selected>
                                                @sale.Username
                                            </option>
                                        }
                                    }
                                }
                                else
                                {
                                    <option value="">
                                    </option>
                                    @foreach (var sale in Model.ListSale)
                                    {
                                        if (sale.Id == Model.Account.SaleId)
                                        {
                                            <option value="@sale.Id" selected>
                                                @sale.Username
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@sale.Id">
                                                @sale.Username
                                            </option>
                                        }
                                    }
                                }
                            </select>

                        </div>
                    </div>
                    <div class="row pt-2">
                        @if (loggedModel.RoleId == (int)ERoleId.Admin || loggedModel.RoleId == (int)ERoleId.Manager)
                        {
                            <div class="col-md-6">
                                <label for="role" class="form-label">Phân quyền</label>
                                <select id="role" class="form-select" name="role">
                                    @foreach (var status in Enum.GetValues(typeof(ERoleId)).Cast<ERoleId>())
                                    {
                                        var statusValue = (int)status;
                                        var statusName = ERoleIdName.GetRoleName(statusValue);
                                        if (statusValue == Model.Account.RoleId)
                                        {
                                            <option value="@statusValue" selected>
                                                @statusName
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@statusValue">
                                                @statusName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        }
                        <div class="col-md-6">
                            <label for="minWeight" class="form-label">Cân nhỏ nhất</label>
                            <input value="@Model.Account.MinWeight" type="number" class="form-control" id="minWeight" placeholder="">
                        </div>
                    </div>

                    <div class="row pt-2">
                        <div class="col-md-6">
                            <label for="postOffice" class="form-label">Bưu cục</label>
                            <select id="postOffice" class="form-select" name="postOffice">
                                <option value="">
                                </option>
                                @foreach (var status in PostOfficeName.GetPostOffice())
                                {
                                    if (status == Model.Account.PostOffice)
                                    {
                                        <option value="@status" selected>
                                            @status
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@status">
                                            @status
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="deliveryMethod" class="form-label">Hình thức nhận hàng</label>
                            <select id="deliveryMethod" class="form-select" name="deliveryMethod">
                                <option value="">
                                </option>
                                @foreach (var status in DeliveryMethodName.GetDeliveryMethod())
                                {
                                    if (status == Model.Account.DeliveryMethod)
                                    {
                                        <option value="@status" selected>
                                            @status
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@status">
                                            @status
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    @if (loggedModel.RoleId == (int)ERoleId.Admin || loggedModel.RoleId == (int)ERoleId.Manager || loggedModel.RoleId == (int)ERoleId.Sale)
                    {
                        <div class="row pt-2">
                            @if (Model.Account.RoleId == (int)ERoleId.TQWarehouseStaff)
                            {
                                <div class="col-md-6">
                                    <label for="transportationType" class="form-label">Loại kiểm kho TQ</label>
                                    <select id="transportationType" class="form-select" name="transportationType">
                                        <option value="0">Tất cả</option>
                                        @foreach (var status in Enum.GetValues(typeof(ETransportationType)).Cast<ETransportationType>())
                                        {
                                            var statusValue = (int)status;
                                            var statusName = ETransportationTypeName.GetTypeName(statusValue);
                                            if (statusValue == Model.Account.TransportationType)
                                            {
                                                <option value="@statusValue" selected>
                                                    @statusName
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@statusValue">
                                                    @statusName
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            @if (Model.Account.RoleId == (int)ERoleId.Sale)
                            {
                                <div class="col-md-6">
                                    <label for="vnWarehouseStaff" class="form-label">Nhân viên giám sát</label>
                                    <select id="vnWarehouseStaffIdSelect" name="vnWarehouseStaff" class="form-select" multiple>
                                        @foreach (var vnWarehouseStaff in Model.ListVNWarehouseStaff)
                                        {
                                            var isSelected = Model.SelectedListVNWarehouseStaffId.Contains(vnWarehouseStaff.Id);
                                            <option value="@vnWarehouseStaff.Id" selected="@(isSelected ? "selected" : null)">
                                                @vnWarehouseStaff.Username
                                            </option>
                                        }
                                    </select>
                                </div>
                            }
                            <div class="col-md-6">
                                <label for="specialShip" class="form-label">PTVC chính ngạch</label>
                                <input type="checkbox" class="form-check-input" id="specialShip" @((Model.Account.SpecialShipId == "5") ? "checked=\"checked\"" : "")>
                                @* <select id="specialShipSelect" name="SpecialShipIds" class="form-select" multiple>
                                    @{
                                        var account = (Account)Model.Account;
                                        var selectedIds = (account.SpecialShipId ?? "")
                                        .Split(',', StringSplitOptions.RemoveEmptyEntries)
                                        .Select(id => id.Trim())
                                        .ToList();
                                    }
                                    @foreach (var warehouse in Model.SpecialShipping)
                                    {
                                        var isSelected = selectedIds.Contains(warehouse.Id.ToString());
                                        <option value="@warehouse.Id" selected="@(isSelected ? "selected" : null)">
                                            @warehouse.Name
                                        </option>
                                    }
                                </select> *@
                            </div>
                        </div>
                    }
                    <div class="row pt-2">
                        <div class="col-md-6">
                            <label for="newPassword" class="form-label">Mật khẩu mới</label>
                            <input type="text" class="form-control" id="newPassword" placeholder="">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button type="button" class="btn btn-primary" id="updateItemButton" onclick="updateItem()">Cập nhật</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card mb-6">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2>Bảng giá riêng</h2>
                    <div>
                        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addModal">
                            <i class="bi bi-plus"></i> Thêm mới
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_PricingSeparateTable", new List<PricingResponse>())
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-2">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3>Sản lượng và đơn trong năm</h3>
            </div>
            <div class="card-body">
                @*                 <div class="row ">
                    <div class="col-md-3">
                        <label for="yearDate" class="form-label">Năm</label>
                        <input type="text" class="form-control datepicker" id="yearDate" name="yearDate" placeholder="">
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-success" onclick="showYearChart()">Lọc kết quả</button>
                    </div>
                </div> *@
                <div class="row mt-4">
                    <div class="col s12">
                        <div class="card user-statistics-card animate fadeLeft">
                            <div class="card-content">
                                <div class="row px-3 pt-3">
                                    <div class="col s3">
                                        <a href="javascript:;" onclick="YearChartData(0, 'black')">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-circle-fill fs-1"></i>
                                                <div>
                                                    <span class="medium-small">Đơn hàng đã giao</span>
                                                    <h5 class="mt-0 mb-0 soDon-Year"></h5>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                    <div class="col s3">
                                        <a href="javascript:;" onclick="YearChartData(1, 'purple')">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-circle-fill fs-1 text-purple"></i>
                                                <div>
                                                    <span class="medium-small">Sản lượng (KG)</span>
                                                    <h5 class="mt-0 mb-0 soKg-Year"></h5>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                    <div class="col s3">
                                        <a href="javascript:;" onclick="YearChartData(2, 'green')">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-circle-fill fs-1 text-success"></i>
                                                <div>
                                                    <span class="medium-small">Sản lượng (Khối)</span>
                                                    <h5 class="mt-0 mb-0 soKhoi-Year"></h5>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                    <div class="col s3">
                                        <a href="javascript:;" onclick="YearChartData(3, 'red')">
                                            <div class="d-flex gap-3 align-items-center">
                                                <i class="bi bi-circle-fill fs-1 text-danger"></i>
                                                <div>
                                                    <span class="medium-small">Doanh số</span>
                                                    <h5 class="mt-0 mb-0 soTien-Year"></h5>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                                <div class="row" style="width: 100%; margin: auto;">
                                    <canvas id="YearChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tạo mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <form id="addForm">
                    <table class="table table-bordered text-center align-middle">
                        <thead>
                            <tr>
                                <th rowspan="2">Phương thức vận chuyển</th>
                                <th rowspan="2">Loại</th>
                                <th colspan="2">Giá trị</th>
                                <th rowspan="2">Đơn giá</th>
                                <th rowspan="2"></th>
                            </tr>
                            <tr>
                                <th>Từ</th>
                                <th>Đến</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td rowspan="2">
                                    <select class="form-select" id="addShip" name="addShip" required>
                                        <option value="">Chọn</option>
                                        @foreach (var item in Model.Shipping)
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    Cân nặng
                                </td>
                                <td><input type="number" class="form-control" id="addRangeWeightMin" value="0" name="weightFrom" required></td>
                                <td><input type="number" class="form-control" id="addRangeWeightMax" value="0" name="weightTo" required></td>
                                <td><input class="form-control input-money" id="addWeightAmount" value="0" name="weightPrice" required></td>
                                <td rowspan="2">
                                    <button type="submit" class="btn btn-success">Lưu</button>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    Số khối
                                </td>
                                <td><input type="number" class="form-control" id="addRangeVolumeMin" value="0" name="volumeFrom" required></td>
                                <td><input type="number" class="form-control" id="addRangeVolumeMax" value="0" name="volumeTo" required></td>
                                <td><input class="form-control input-money" id="addVolumeAmount" value="0" name="volumePrice" required></td>
                            </tr>
                        </tbody>
                    </table>
                </form>
            </div>
        </div>
    </div>
</div>


