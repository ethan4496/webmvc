@section Scripts {
    <script src="~/js/createLineChart.js"></script>

    <script>
        $(document).ready(function () {
            $('#vnWarehouseStaffIdSelect').select2({
                placeholder: "Chọn nhân viên kho VN",
                width: '100%'
            });
        });
        $(document).ready(function () {
            loadPricingSeparateTable();
            showYearChart();
        });
        function loadPricingSeparateTable() {
            showLoading();
            $.ajax({
                url: `/Account/GetPricingSeparate?id=${@Model.Account.Id}`,
                type: 'GET',
                success: function (data) {
                    $('#table-container').html(data);
                },
                error: function (response) {
                    showToast(response.responseJSON?.Message, response.responseJSON?.Type, false);
                },
                complete: function () {
                    hideLoading();
                }
            });
        }
        function showYearChart() {
            YearChart();
            YearChartData(3, 'red');
        }
        function YearChart() {
            // const yearDateInput = $('#yearDate').val();
            // const yearDate = yearDateInput ? parseDate(yearDateInput) : null;
            $.ajax({
                url: '/Statistic/GetYearChartOfAccount'+`?id=${@Model.Account.Id}`,
                // data: { dataDate: yearDate ? yearDate : '' },
                type: 'GET',
                success: function (data) {
                    $(".soDon-Year").text(Math.floor(data.Order));
                    $(".soKg-Year").text(data.Weight.toFixed(2));
                    $(".soKhoi-Year").text(data.Volume.toFixed(2));
                    $(".soTien-Year").text(data.TotalPriceVND.toLocaleString('en-US'));
                },
                error: function () {
                }
            });
        }
        function YearChartData(index, colorW) {
            const yearDate = $('#yearDate').val() ? parseDate($('#yearDate').val()) : null;
            $.ajax({
                url: '/Statistic/GetYearChartDataOfAccount'+`?id=${@Model.Account.Id}`,
                data: { type: index },
                type: 'GET',
                success: function (response) {
                    createChart('YearChart', response.Data, colorW, response.Title);
                },
                error: function () { }
            });
        }
        $('#updateItemButton').click(function () {
            const username = $('#username').val().trim();
            const fullName = $('#fullName').val().trim();
            const email = $('#email').val().trim();
            const phone = $('#phone').val().trim();
            const address = $('#address').val().trim();
            const roleId = parseInt($('#role').val()) || 2;
            const saleId = parseInt($('#sale').val()) || null;
            const minWeight = parseFloat($('#minWeight').val()) || null;
            const postOffice = $('#postOffice').val().trim();
            const deliveryMethod = $('#deliveryMethod').val().trim();
            const newPassword = $('#newPassword').val().trim() || null;
            const transportationType = parseInt($('#transportationType').val()) || null;

            const selectedIds = $('#vnWarehouseStaffIdSelect').val();
            // const joinedIds = selectedIds ? selectedIds.join(',') : '';
            const specialShipId = $('#specialShip').prop('checked') ? '5' : null
            if (username === "" || email === "" || phone === "" || address === "" || fullName === "" || newPassword === "") {
                showToast("Vui lòng điền thông tin còn thiếu", 2, false);
                return;
            }
            const request = {
                Username: username,
                Email: email,
                Phone: phone,
                Address: address,
                FullName: fullName,
                RoleId: roleId,
                SaleId: saleId,
                MinWeight: minWeight,
                PostOffice: postOffice,
                DeliveryMethod: deliveryMethod,
                NewPassword: newPassword,
                TransportationType: transportationType,
                SpecialShipId: specialShipId,
                VNWarehouseStaffIds : selectedIds
            };
            disableButton();
            $.ajax({
                url: `/Account/Update?id=${@Model.Account.Id}`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify(request),
                success: function (response) {
                    showToast(response.Message, response.Type, true);
                },
                error: function (response) {
                    showToast(response.responseJSON?.Message, response.responseJSON?.Type, false);
                },
                complete: function () {
                    enableButton();
                }
            });
        });

        document.getElementById("addForm").addEventListener("submit", async function (event) {
            event.preventDefault();

            const ship = $("#addShip").val();
            const rangeWeightMin = $("#addRangeWeightMin").val();
            const rangeWeightMax = $("#addRangeWeightMax").val();
            const pricePerWeightUnit = getRawValue($("#addWeightAmount").val());
            const rangeVolumeMin = $("#addRangeVolumeMin").val();
            const rangeVolumeMax = $("#addRangeVolumeMax").val();
            const pricePerVolumeUnit = getRawValue($("#addVolumeAmount").val());

            const createData = {
                ShipId: ship,
                RangeWeightMin: rangeWeightMin,
                RangeWeightMax: rangeWeightMax,
                PricePerWeightUnit: pricePerWeightUnit,
                RangeVolumeMin: rangeVolumeMin,
                RangeVolumeMax: rangeVolumeMax,
                PricePerVolumeUnit: pricePerVolumeUnit,
            }
            disableButton();
            $.ajax({
                url: `/Account/CreatePricingSeparate?id=${@Model.Account.Id}`,
                type: "POST",
                data: { Request: createData },
                success: function (response) {
                    showToast(response.Message, response.Type, false);
                    loadPricingSeparateTable();
                    $("#addModal").modal("hide");
                },
                error: function (response) {
                    showToast(response.responseJSON?.Message || "Lỗi không xác định", response.responseJSON?.Type || 2, false);
                },
                complete: function () {
                    enableButton();
                }
            });
        });

        function editItem(item) {
            $("#editShip").val(item.ShipId);
            $("#editType").val(item.Type);
            $("#editRangeMin").val(item.RangeMin);
            $("#editRangeMax").val(item.RangeMax);
            $("#editAmount").val(item.PricePerUnit.toLocaleString("en-US"));
            // Lưu ID item vào form để gửi khi cập nhật
            $("#editForm").data("item-id", item.Id);
        }

        $("#editForm").submit(async function (event) {
            event.preventDefault();

            const itemId = $(this).data("item-id");
            const ship = $("#editShip").val();
            const type = $("#editType").val();
            const rangeMin = $("#editRangeMin").val();
            const rangeMax = $("#editRangeMax").val();
            const pricePerUnit = getRawValue($("#editAmount").val());

            const updateData = {
                ShipId: ship,
                RangeMin: rangeMin,
                RangeMax: rangeMax,
                PricePerUnit: pricePerUnit,
                Type: type,
                Id : itemId
            }

            disableButton();
            $.ajax({
                url: `/Account/UpdatePricingSeparate?id=${@Model.Account.Id}`,
                type: "PUT",
                data: { Request: updateData },
                success: function (response) {
                    showToast(response.Message, response.Type, false);
                    loadPricingSeparateTable();
                    $("#editModal").modal("hide");
                },
                error: function (response) {
                    showToast(response.responseJSON?.Message || "Lỗi không xác định", response.responseJSON?.Type || 2, false);
                },
                complete: function () {
                    enableButton();
                }
            });
        });

        function deletePricing(id) {
            showConfirmModal('Bạn chắc chắn muốn xóa bảng giá riêng này?', function () {
                disableButton();
                $.ajax({
                url: `/Account/DeletePricingSeparate?accountId=${@Model.Account.Id}&id=${id}`,
                    type: 'DELETE',
                    success: function (response) {
                        showToast(response.Message, response.Type, false);
                        loadPricingSeparateTable();
                    },
                    error: function (response) {
                        showToast(response.responseJSON?.Message, response.responseJSON?.Type, false);
                    },
                    complete: function () {
                        enableButton();
                    }
                });
            });
        }
    </script>
}
