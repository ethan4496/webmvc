@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model AccountProfile
@{
    ViewData["Title"] = "Thông tin tài khoản";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-center">
        <div class="card shadow p-4 w-50" style=" min-width: 40rem; ">
            <h2 class="text-center mb-4">Thông Tin Tài Khoản</h2>
            <div class="text-center">
                <div class="avatar-wrapper" id="avatarContainer">
                    <img id="avatar" src="@Model.Avatar" alt="">
                    <label for="uploadAvatar"><i class="bi bi-camera"></i></label>
                    <input type="file" id="uploadAvatar" accept="image/*">
                </div>
            </div>
            <form id="accountForm" class="mt-3">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username" value="@Model.Username" readonly disabled>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" value="@Model.Email">
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="fullName" value="@Model.FullName">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="text" class="form-control" id="phone" value="@Model.Phone">
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" class="form-control" id="address" value="@Model.Address">
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="warehouseTo" class="form-label">Kho VN</label>
                        <select id="warehouseTo" class="form-select" required>
                            <option value="">Chọn Kho VN</option>
                            @foreach (var item in Model.Warehouses)
                            {
                                if (item.Id == Model.ToWarehouseId)
                                {
                                    <option value=@item.Id selected>@item.Name</option>
                                }
                                else
                                {
                                    <option value=@item.Id>@item.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6 position-relative">
                        <label for="password" class="form-label">Mật khẩu mới</label>
                        <input type="password" class="form-control" id="password" placeholder="">
                        <span style=" top: 70%; " class="toggle-password position-absolute  end-0 translate-middle-y me-3"
                              onclick="togglePassword('password', this)">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>
                    <div class="col-md-6 position-relative">
                        <label for="confirmPassword" class="form-label">Nhập lại mật khẩu</label>
                        <input type="password" class="form-control" id="confirmPassword" placeholder="">
                        <span style=" top: 70%; " class="toggle-password position-absolute end-0 translate-middle-y me-3"
                              onclick="togglePassword('confirmPassword', this)">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>
                </div>
                <div class="text-center">
                    <button type="submit" class="btn btn-primary w-50">Cập Nhật</button>

                </div>
            </form>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#uploadAvatar').change(function (e) {
            let reader = new FileReader();
            reader.onload = function (e) {
                $('#avatar').attr('src', e.target.result);
            }
            reader.readAsDataURL(this.files[0]);
        });

        $('#accountForm').submit(function (e) {
            e.preventDefault();
            let email = $('#email').val().trim();
            let phone = $('#phone').val().trim();
            let address = $('#address').val().trim();
            let fullName = $('#fullName').val().trim();
            let password = $('#password').val().trim();
            let confirmPassword = $('#confirmPassword').val().trim();

            if (email === "" || phone === "" || address === "" || fullName === "") {
                showToast("Vui lòng điền thông tin còn thiếu", 2, false);
                return;
            }
            if (password !== confirmPassword) {
                showToast("Mật khẩu nhập lại không khớp", 2, false);
                return;
            }
            let formData = new FormData();
            formData.append("Email", email);
            formData.append("Phone", phone);
            formData.append("Address", address);
            formData.append("FullName", fullName);
            formData.append("Password", password);
            formData.append("ConfirmPassword", confirmPassword);
            formData.append("ToWarehouseId", $("#warehouseTo").val());
            const imageFile = $("#uploadAvatar")[0].files[0];
            if (imageFile) {
                formData.append("FileNewAvatar", imageFile);
            }

            disableButton();
            $.ajax({
                url: '/Account/Profile',
                type: 'PUT',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    showToast("Cập nhật thành công", 3, true);
                },
                error: function (response) {
                    showToast(response.responseJSON.Message, response.responseJSON.Type, false);
                },
                complete: function () {
                    enableButton();
                }
            });
        });
    });

    function togglePassword(id, icon) {
        let input = document.getElementById(id);
        let iconElement = icon.querySelector("i");

        if (input.type === "password") {
            input.type = "text";
            iconElement.classList.remove("bi-eye");
            iconElement.classList.add("bi-eye-slash");
        } else {
            input.type = "password";
            iconElement.classList.remove("bi-eye-slash");
            iconElement.classList.add("bi-eye");
        }
    }
</script>
<style>
    .avatar-wrapper {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }

        .avatar-wrapper img {
            display: block;
            width: 18rem;
            height: 18rem;
            border-radius: 50%;
            border: 4px solid #fff;
            box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
        }

        .avatar-wrapper label {
            width: 18rem;
            height: 18rem;
            position: absolute;
            bottom: -40%;
            left: 50%;
            transform: translateX(-50%);
            color: black;
            border-radius: 50%;
            padding: 8px;
            cursor: pointer;
        }

            .avatar-wrapper label i {
                font-size: 18px;
            }

        .avatar-wrapper input {
            display: none;
        }
</style>