@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<Notification>
<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Nội dung</th>
                    <th class="text-center">Loại</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center">@((ViewBag.CurrentPage - 1) * (ViewBag.PageSize) + i + 1)</td>
                        <td>
                            <a href="@Model[i].WebUrl" target="_blank" onclick="readNotification(@Model[i].Id)">
                                <div class="notification-item p-2 ">
                                    <strong>@Model[i].Title</strong>
                                    <p class="text-muted m-0">@Model[i].Content</p>
                                </div>
                            </a>
                        </td>
                        <td class="text-center">
                            @switch (Model[i].Type)
                            {
                                case 1:
                                    @:Đơn hàng
                                    break;
                                case 2:
                                    @:Khách hàng
                                    break;
                                case 3:
                                    @:Voucher
                                    break;
                                default:
                                    @:Tất cả
                                    break;
                            }
                        </td>
                        <td class="text-center">@(Model[i].IsRead ? "Đã xem" : "Mới")</td>
                        <td class="text-center">@Model[i].Created.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
