@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<PricingResponse>
<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Kho và phương thức </th>
                    <th class="text-center">Loại</th>
                    <th class="text-center">Giá trị từ</th>
                    <th class="text-center">Giá trị đến</th>
                    <th class="text-center">Đơn giá</th>
                    <th class="text-center">Ngày cập nhật</th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center align-content-center">@((ViewBag.CurrentPage - 1) * (ViewBag.PageSize) + i + 1)</td>
                        <td class="align-content-center">
                            <p>Kho TQ: <span class="fw-bold">@Model[i].FromWarehouseName</span></p>
                            <p>Kho VN: <span class="fw-bold">@Model[i].ToWarehouseName</span></p>
                            <p>Phương thức vận chuyển: <span class="fw-bold">@Model[i].ShipName</span></p>
                        </td>
                        <td class="text-center align-content-center">@Model[i].TypeName</td>
                        <td class="text-center align-content-center">@Model[i].RangeMin</td>
                        <td class="text-center align-content-center">@Model[i].RangeMax</td>
                        <td class="text-center align-content-center">@string.Format("{0:N0}", Model[i].PricePerUnit) đ</td>
                        <td class="text-center align-content-center">@Model[i].Updated?.ToString("dd/MM/yyyy")</td>
                        <td class="text-center align-content-center">
                            <p>
                                <button class="btn btn-sm btn-warning" onclick='editItem(@Html.Raw(Json.Serialize(Model[i])))' data-bs-toggle="modal" data-bs-target="#editModal">Cập nhật</button>
                            </p>
                            <p>
                                <button class="btn btn-sm btn-danger" onclick='deletePricing(@Model[i].Id)'>Xóa</button>
                            </p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
