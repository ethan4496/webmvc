    function showTableDT() {
        const fromDateInput = $('#fromDT').val();
        const fromDateParse = fromDateInput ? parseDate(fromDateInput) : null;
        const fromDate = fromDateParse ? fromDateParse : '';

        const toDateInput = $('#toDT').val();
        const toDateParse = toDateInput ? parseDate(toDateInput) : null;
        const toDate = toDateParse ? toDateParse : '';
        $.ajax({
            url: '/Statistic/GetStatisticTable2', // Thay thế URL với controller của bạn
            type: 'GET',
            data: {
                id: @Model,
                fromDate: fromDate,
                toDate: toDate,
                shipId: 3,
            },
            success: function (data) {
                const tableBody = $('#tableDT tbody'); // Chỉ định bảng bằng ID
                tableBody.empty(); // Xóa các dòng cũ

                data.forEach((item, index) => {
                    const row = `
                                                                <tr>
                                                                    <td class="text-center">${index + 1}</td>
                                                                        <td class="text-center">${item.Username}</td>
                                                                        <td class="text-center">${item.Phone}</td>
                                                                        <td class="text-center">${item.TotalPriceVND.toLocaleString('en-US')}</td>
                                                                </tr>
                                                            `;
                    tableBody.append(row);
                });
            },
            error: function () {
            }
        });
    }
    function exportTableDT() {
        const fromDateInput = $('#fromDT').val();
        const fromDateParse = fromDateInput ? parseDate(fromDateInput) : null;
        const fromDate = fromDateParse ? fromDateParse : '';

        const toDateInput = $('#toDT').val();
        const toDateParse = toDateInput ? parseDate(toDateInput) : null;
        const toDate = toDateParse ? toDateParse : '';

        const params = new URLSearchParams({
            'id': @Model,
            'fromDate': fromDate,
            'toDate': toDate,
            'shipId': 4
        });
        fetch('/Statistic/ExportStatisticTable2' + `?${params.toString()}`)
            .then(response => response.blob())
            .then(blob => {
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = "Doanh số DT trong tháng.xlsx";
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            })
            .catch(error => console.error("Lỗi khi tải file mẫu:", error));
    }
</script>
