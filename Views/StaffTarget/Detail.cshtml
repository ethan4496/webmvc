                    <input type="text" class="form-control datepicker" id="weekDate" name="weekDate" placeholder="">
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" class="btn btn-success" onclick="showWeekChart()">Lọc kết quả</button>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col s12">
                    <div class="card user-statistics-card animate fadeLeft">
                        <div class="card-content">
                            <div class="row px-3 pt-3">
                                <div class="col s3">
                                    <a href="javascript:;" onclick="WeekChartData(0, 'black')">
                                        <div class="d-flex gap-3 align-items-center">
                                            <i class="bi bi-circle-fill fs-1"></i>
                                            <div>
                                                <span class="medium-small">Đơn hàng đã giao</span>
                                                <h5 class="mt-0 mb-0 soDon-Week"></h5>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col s3">
                                    <a href="javascript:;" onclick="WeekChartData(1, 'purple')">
                                        <div class="d-flex gap-3 align-items-center">
                                            <i class="bi bi-circle-fill fs-1 text-purple"></i>
                                            <div>
                                                <span class="medium-small">Sản lượng (KG)</span>
                                                <h5 class="mt-0 mb-0 soKg-Week"></h5>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col s3">
                                    <a href="javascript:;" onclick="WeekChartData(2, 'green')">
                                        <div class="d-flex gap-3 align-items-center">
                                            <i class="bi bi-circle-fill fs-1 text-success"></i>
                                            <div>
                                                <span class="medium-small">Sản lượng (Khối)</span>
