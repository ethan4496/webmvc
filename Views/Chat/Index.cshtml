@using WebMVC.Models.Responses
@model LoggedModel
@{
    ViewData["Title"] = "Tin nhắn";
}
<div class="container-fluid mt-4 ">
    <div>
        <div class="row ">
            <div class="col-md-4 card" style=" height: 80vh;">
                <div class="card-body">
                    <div class="row pb-2">
                        <div class="col-md-9">
                            <select class="form-select" id="username" style="width:100%" name="Username"></select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button type="button" class="btn btn-primary" onclick="loadConversion(1)"><i class="bi bi-search"></i></button>
                        </div>
                    </div>
                    @await Html.PartialAsync("_ChatConversationTable", new List<ChatConversationResponse>())
                </div>
            </div>
            <div class="col-md-8 card " style=" height: 80vh;">
                <div class="chatbox card-body">
                    <div class="chatbox-header">

                    </div>
                    <div class="chatbox-body" id="chatMessages">
                    </div>
                    @*                     <div id="imagePreviewContainer" style="display: none;">
                        <img id="imagePreview" style="max-width: 100px; max-height: 100px; border-radius: 8px;">
                        <button id="removeImageBtn" class="btn">❌</button>
                    </div>
                    <div class="chat-input-container">
                        <textarea type="text" id="chatInput" class="form-control" placeholder="Nhập tin nhắn..."></textarea>
                        <input type="file" id="imageInput" accept="image/*" style="display: none;">
                        <button id="uploadImageBtn" class="btn btn-primary"><i class="bi bi-camera-fill"></i></button>
                        <button class="btn btn-primary" onclick="sendGroupMessage()">Gửi</button>
                    </div> *@
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            document.getElementById("chatWindow").innerHTML = "";
            localStorage.setItem("chatLanguage", "vi");
            chatLanguage = "vi";
            loadConversion(1);
        });
        function loadConversion(page){
            const request = {
                Page: page,
                AccountId: $('#username').val() || null,
            };
            showLoading();
            $.ajax({
                url: '/Chat/GetAllConversation',
                data: request,
                type: 'GET',
                success: function (data) {
                    $('#table-container').html(data);
                },
                error: function () {
                },
                complete: function () {
                    hideLoading();
                }
            });
        }

        async function openChatGroup(conversation){
            document.getElementById("chatMessages").innerHTML = "";
            try {
                // Gửi tin nhắn và đợi cho tới khi hoàn tất
                await connection.invoke("JoinChatGroup", conversation.User1Id, conversation.User2Id);
            } catch (err) {
                console.log("Error sending message: ", err.toString());
            }
            currentPage = 1;
            hasMoreMessages = true;
            isLoading = false;
            const receiver = {
                Id : conversation.User2Id,
                ConversationId : conversation.Id,
            }
            currentConversation = receiver;
            loadGroupMessages(receiver);
        }

