        function loadGroupMessages(receiver) {
            if (isLoading || !hasMoreMessages) return;
            isLoading = true;
            $.ajax({
                url: `/Chat/GetGroupMessages?conversationId=${receiver.ConversationId}&page=${currentPage}&pageSize=${pageSize}`,
                type: 'GET',
                success: function (messages) {
                    if (messages.length < pageSize) {
                    }
                    const chatMessages = document.getElementById("chatMessages");
                    let firstMessage = chatMessages.firstChild; // Ghi nhớ vị trí tin nhắn đầu tiên

                    messages.forEach(message => {
                        const messageDiv = document.createElement("div");
                        // messageDiv.classList.add("group-message");

                        // const innerDiv = document.createElement("div");
                        // if (message.SenderId == @Model.Id) {
                        //     innerDiv.classList.add("sent");
                        // } else {
                        //     innerDiv.classList.add("received");
                        // }

                        // // Hiển thị ngày tạo tin nhắn
                        // const dateElement = document.createElement("i");
                        // dateElement.classList.add("create-date");
                        // dateElement.textContent = message.SenderUsername + "-"+ message.CreatedAt || "Không rõ ngày"; // Thay CreatedAt bằng dữ liệu ngày gửi thực tế

                        // // Hiển thị nội dung tin nhắn hoặc hình ảnh
                        // const messageContent = document.createElement("div");
                        // messageContent.classList.add("message-content");

                        // if (message.FileUrl) {
                        //     messageContent.innerHTML = `<img src="${message.FileUrl}" alt="Image" style="max-width: 100%; border-radius: 8px; cursor: pointer;" onclick="window.open(this.src)">`;
                        // } else {
                        //     messageContent.textContent = message.Message;
                        // }
                        // innerDiv.appendChild(messageContent);
                        // innerDiv.appendChild(dateElement);
                        // messageDiv.appendChild(innerDiv);

                        // chatMessages.prepend(messageDiv);
                        if (message.SenderId == receiver.Id) {
                            messageDiv.classList.add("message", "received");
                        } else {
                            messageDiv.classList.add("message", "sent");
                        }
                        if (message.FileUrl) {
                            messageDiv.innerHTML = `<img src="${message.FileUrl}" alt="Image" style="max-width: 100%; border-radius: 8px;cursor: pointer;" onclick="window.open(this.src)">`;
                        } else {
                            messageDiv.innerHTML = chatLanguage == "vi" ? message.Message : message.MessageSecondLanguage;
                        }
                        chatMessages.prepend(messageDiv);
                    });


                    // Cuộn xuống tin nhắn cũ nhất vừa load
                    if (firstMessage instanceof HTMLElement) {
                        firstMessage.scrollIntoView();
                    } else {
                        chatMessages.scrollTop = chatMessages.scrollHeight; // Cuộn xuống cuối nếu lần đầu load
                    }
                    currentPage++; // Tăng số trang để lần sau load tiếp
                    isLoading = false;
                },
                error: function () {
                },
                complete: function () {
                    hideLoading();
                    isLoading = false;
                }
            });
        }

        $("#username").select2({
            placeholder: "Chọn username",
            allowClear: true,
            theme: "bootstrap-5",
            ajax: {
                url: "/Account/Paging",
                dataType: 'json',
                delay: 250,
                data: function (params) {
                    return {
                        Username: params.term || '',
                        PageIndex: params.page || 1,
                        PageSize: 10
                    };
                },
                processResults: function (data, params) {
                    return {
                        results: data.Items.map(item => ({
                            id: item.Id,
                            text: item.Username
                        })),
                        pagination: {
                            more: data.PageIndex < data.TotalPage && params.term
                        }
                    };
                },
                cache: true
            }
        });

    </script>
}
