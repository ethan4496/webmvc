@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<ChatConversationResponse>
<div id="table-container">
    <div class="table-content" style="height: 60vh;">
        <table class="table table-hover table-bordered">

            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="align-content-center">
                            <a href="javascript:;" onclick='openChatGroup(@Html.Raw(Json.Serialize(Model[i])))'>
                                <div class="notification-item p-2 ">
                                    <strong>@($"{Model[i].SenderUsername}, {Model[i].ReceiverUsername}")</strong>
                                    <p class="text-muted m-0">@Model[i].LastMessage</p>
                                </div>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">
                @if (ViewBag.CurrentPage > 2)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadConversion(1)">Đầu</a>
                    </li>
                }
                @{
                    int startPage = Math.Max(1, ViewBag.CurrentPage - 1); // Bắt đầu từ trang gần trước
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 1); // Kết thúc ở trang gần sau
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadConversion(@i)">@i</a>
                    </li>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages - 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadConversion(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
