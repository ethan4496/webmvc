@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<ReportRevenueResponse>
<div id="table-container">
    <div class="table-content card mb-2">
        @if (Model.Count > 0)
        {
            <div class="card-header d-flex align-items-center">
                @Html.Raw(Model[0].TableTitle)
            </div>
        }
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Tên khách</th>
                    <th class="text-center">Mã khách</th>
                    <th class="text-center">Tổng đơn</th>
                    <th class="text-center">Tổng Kg</th>
                    <th class="text-center">Tổng khối</th>
                    <th class="text-center">Tổng tiền</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center align-content-center">@((ViewBag.CurrentPage - 1) * (ViewBag.PageSize) + i + 1)</td>
                        <td class="text-center align-content-center">@Model[i].Username</td>
                        <td class="text-center align-content-center">@Model[i].AccountId</td>
                        <td class="text-center align-content-center">@Model[i].Order</td>
                        <td class="text-center align-content-center">@Model[i].Weight</td>
                        <td class="text-center align-content-center">@Model[i].Volume</td>
                        <td class="text-center align-content-center">@string.Format("{0:N0}", Model[i].TotalPriceVND) </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
