    <script>
        function showToast(message, type, isReload) {
            let bgColor = "green";
            switch (type) {
                case 1:
                    bgColor = "red"
                    break;
                case 2:
                    bgColor = "#ffc107"
                    break;
                case 3:
                    bgColor = "blue"
                    break;
                default:
                    bgColor = "green";
                    break;
            }
            Toastify({
                text: message,
                duration: 3000,
                gravity: "top", // Vị trí top
                position: "right", // Hiển thị bên phải
                backgroundColor: bgColor,
            }).showToast();
            if (isReload) {
                setTimeout(
                    function () {
                        window.location.reload();
                    },
                    1000
                );
            }
        }

        function disableButton() {
            // Chọn tất cả các button và link (a) trên trang
            const elements = document.querySelectorAll('button, a');

            elements.forEach(el => {
                // Thêm lớp 'disabled' để hiển thị trạng thái không hoạt động
                el.classList.add('disabled');

                // Disable nút nếu là button
                if (el.tagName.toLowerCase() === 'button') {
                    el.disabled = true;
                }

                // Ngăn chặn hành động mặc định nếu là link (a)
                if (el.tagName.toLowerCase() === 'a') {
                    el.addEventListener('click', function (event) {
                        event.preventDefault();
                    });
                }
            });
        }

        function enableButton() {
            // Chọn tất cả các button và link (a) có lớp 'disabled'
            const elements = document.querySelectorAll('button, a');

            elements.forEach(el => {
                // Xóa lớp 'disabled' để khôi phục trạng thái hoạt động
                el.classList.remove('disabled');

                // Bật lại nút nếu là button
                if (el.tagName.toLowerCase() === 'button') {
                    el.disabled = false;
                }

                // Loại bỏ sự kiện 'click' ngăn hành động mặc định nếu là link (a)
                if (el.tagName.toLowerCase() === 'a') {
                    const newElement = el.cloneNode(true); // Tạo bản sao không có sự kiện
                    el.replaceWith(newElement); // Thay thế thẻ hiện tại bằng bản sao
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
