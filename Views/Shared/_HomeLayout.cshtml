    <script>
        $(document).ready(function () {
            Slide();
            $(".myIcon").on('click', function () {
                $(".tooltips-mess").toggleClass("open-tool");
            });
            const $tool = $('.tooltips-mess')
            $(document).mouseup(e => {
                if (!$tool.is(e.target)
                    && $tool.has(e.target).length === 0) {
                    $tool.removeClass('open-tool');
                }
            });
        })
        function Slide() {
            var swiper = new Swiper(".myIcon", {
                spaceBetween: 30,
                centeredSlides: true,
                // allowTouchMove : false,
                autoplay: {
                    delay: 2500,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: ".swiper-pagination",
                    clickable: true,
                },
                navigation: {
                    nextEl: ".swiper-button-next",
                    prevEl: ".swiper-button-prev",
                },
            });
        }
    </script>
