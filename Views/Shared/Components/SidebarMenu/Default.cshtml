    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sidebar = document.getElementById("sidebar");
            const imageLogo = document.getElementById("sidebar-header-img");
            const mainTag = document.getElementById("mainTag");

            sidebar.classList.add("collapsed-sidebar"); // luôn bắt đầu ở trạng thái ẩn
            if (imageLogo) imageLogo.style.display = "none";
            if (mainTag) mainTag.style.paddingLeft = "80px";
            sidebar.addEventListener("mouseenter", function () {
                sidebar.classList.remove("collapsed-sidebar");

                if (imageLogo) imageLogo.style.display = "flex";
@*                 if (mainTag) mainTag.style.paddingLeft = "260px";
 *@            });

            sidebar.addEventListener("mouseleave", function () {
                sidebar.classList.add("collapsed-sidebar");

                if (imageLogo) imageLogo.style.display = "none";
                if (mainTag) mainTag.style.paddingLeft = "80px";
            });
        });
    </script>

