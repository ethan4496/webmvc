<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <!-- Thêm trong thẻ <head> -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jquery-datetimepicker@2.5.20/build/jquery.datetimepicker.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/jquery-datetimepicker@2.5.20/build/jquery.datetimepicker.full.min.js"></script>


    <link rel="stylesheet" href="~/css/site.css?v=@DateTime.Now.Ticks" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat.css?v=@DateTime.Now.Ticks" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">
        @await Component.InvokeAsync("NavigationMenu")
        <div class="container-fluid main px-3">
            <!-- Sidebar -->
            @await Component.InvokeAsync("SidebarMenu")

            <!-- Nội dung chính -->
            <div id="mainTag" role="main" class="">
                @RenderBody()
            </div>
        </div>
        @await Component.InvokeAsync("ChatWindow")

    </div>


    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmModalLabel">Xác nhận thao tác</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="confirmModalMessage">Are you sure you want to proceed?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bỏ qua</button>
                    <button type="button" class="btn btn-danger" id="confirmModalConfirmButton">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
    <div id="loading" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); justify-content: center; align-items: center; z-index: 9999;">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <script>
        function showToast(message, type, isReload) {
            let bgColor = "green";
            switch (type) {
                case 1:
                    bgColor = "red"
                    break;
                case 2:
                    bgColor = "#ffc107"
                    break;
                case 3:
                    bgColor = "blue"
                    break;
                default:
                    bgColor = "green";
                    break;
            }
            Toastify({
                text: message,
                duration: 3000,
                gravity: "top", // Vị trí top
                position: "right", // Hiển thị bên phải
                backgroundColor: bgColor,
            }).showToast();
            if (isReload) {
                setTimeout(
                    function () {
                        window.location.reload();
                    },
                    1000
                );
            }
        }

        function disableButton() {
            // Chọn tất cả các button và link (a) trên trang
            const elements = document.querySelectorAll('button, a');

            elements.forEach(el => {
                // Thêm lớp 'disabled' để hiển thị trạng thái không hoạt động
                el.classList.add('disabled');

                // Disable nút nếu là button
                if (el.tagName.toLowerCase() === 'button') {
                    el.disabled = true;
                }

                // Ngăn chặn hành động mặc định nếu là link (a)
                if (el.tagName.toLowerCase() === 'a') {
                    el.addEventListener('click', function (event) {
                        event.preventDefault();
                    });
                }
            });
        }

        function enableButton() {
            // Chọn tất cả các button và link (a) có lớp 'disabled'
            const elements = document.querySelectorAll('button, a');

            elements.forEach(el => {
                // Xóa lớp 'disabled' để khôi phục trạng thái hoạt động
                el.classList.remove('disabled');

                // Bật lại nút nếu là button
                if (el.tagName.toLowerCase() === 'button') {
                    el.disabled = false;
                }

                // Loại bỏ sự kiện 'click' ngăn hành động mặc định nếu là link (a)
                if (el.tagName.toLowerCase() === 'a') {
                    const newElement = el.cloneNode(true); // Tạo bản sao không có sự kiện
                    el.replaceWith(newElement); // Thay thế thẻ hiện tại bằng bản sao
                }
            });
        }

        function showConfirmModal(message, confirmCallback) {
            // Cập nhật nội dung của modal
            document.getElementById('confirmModalMessage').textContent = message;

            // Lấy nút "Confirm"
            const confirmButton = document.getElementById('confirmModalConfirmButton');

            // Xóa sự kiện trước đó để tránh bị chồng lặp
            confirmButton.onclick = null;

            // Gán sự kiện cho nút "Confirm"
            confirmButton.onclick = function () {
                // Gọi hàm callback khi người dùng nhấn "Confirm"
                confirmCallback();

                // Ẩn modal sau khi xác nhận
                const modalInstance = bootstrap.Modal.getInstance(document.getElementById('confirmModal'));
                modalInstance.hide();
            };

            // Hiển thị modal
            const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
            modal.show();
        }

        function showLoading() {
            $("#loading").css("display", "flex");
            $("#loading").show();
            $("body").css("overflow", "hidden");
        }

        function hideLoading() {
            $("#loading").hide();
            $("body").css("overflow", "auto");
        }
        // Định dạng ngày cho tất cả các input type="date"
        $(document).ready(function () {
            $('.datepicker').datetimepicker({
                timepicker: false,
                format: 'd/m/Y'
            });
        });
        function parseDate(dateStr) {
            if (!dateStr) return null;

            const [day, month, year] = dateStr.split('/');
            return `${year}-${month}-${day}`;
        }


        // Hàm chuyển đổi ngày từ YYYY-MM-DD sang dd/mm/yyyy
        function formatDateForInput(dateString) {
            if (!dateString) return "";

            const date = new Date(dateString);
            if (isNaN(date.getTime())) return "";

            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();

            return `${day}/${month}/${year}`;
        }


        function readNotiInLayout(id){
            disableButton();
            $.ajax({
                url: `/Notification/Read?id=${id}`,
                type: 'PUT',
                success: function () {
                },
                error: function (response) {
                    showToast(response.responseJSON.Message, response.responseJSON.Type, false);
                },
                complete: function () {
                    enableButton();
                }
            });
        }
    </script>
    <!-- Kết nối SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/chat.js?v=@DateTime.Now.Ticks"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.querySelectorAll(".input-money").forEach(function (input) {
            // Khi nhập, chỉ cho phép số và cập nhật format
            input.addEventListener("input", function () {
                let value = this.value.replace(/[^\d.-]/g, ""); // Xóa dấu phẩy
                if (!isNaN(value) && value !== "") {
                    this.value = Number(value).toLocaleString("en-US"); // Format lại
                }
            });

            // Khi blur khỏi input, hiển thị lại số có dấu `,`
            input.addEventListener("blur", function () {
                formatInput(this);
            });
        });

        // Hàm định dạng tất cả các input tiền tệ khi trang load
        function formatAllInputs() {
            document.querySelectorAll(".input-money").forEach(function (input) {
                formatInput(input);
            });
        }

        // Hàm format 1 input cụ thể
        function formatInput(input) {
            let value = input.value.replace(/,/g, ""); // Xóa dấu `,`
            if (!isNaN(value) && value !== "") {
                input.value = Number(value).toLocaleString("en-US"); // Format lại
            }
        }

        // Hàm lấy giá trị số không có dấu `,`
        function getRawValue(input) {
            return input.replace(/,/g, "");
        }

        function handleInput() {
            let value = this.value.replace(/[^\d.-]/g, "");
            if (!isNaN(value) && value !== "") {
                this.value = Number(value).toLocaleString("en-US");
            }
        }

        function handleBlur() {
            let value = this.value.replace(/,/g, "");
            if (!isNaN(value) && value !== "") {
                this.value = Number(value).toLocaleString("en-US");
            }
        }
        function bindInputMoneyEvents() {
            document.querySelectorAll(".input-money").forEach(function (input) {
                input.removeEventListener("input", handleInput);
                input.removeEventListener("blur", handleBlur);

                input.addEventListener("input", handleInput);
                input.addEventListener("blur", handleBlur);
            });
        }
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.addEventListener("keydown", function (e) {
                // Kiểm tra nếu nhấn Enter (phím mã 13)
                if (e.key === "Enter" || e.keyCode === 13) {
                    // Tìm nút có class btn-search (đầu tiên)
                    var btn = document.querySelector(".btn-search");
                    if (btn) {
                        btn.click();
                    }
                }
            });
        });
    </script>

</body>
</html>
