@using WebMVC.Models.Responses
@using WebMVC.Ultilities.Enums
@model List<BigPackageResponse>

<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    <th class="text-center">#</th>
                    <th class="text-center">Mã bao</th>
                    <th class="text-center">Đối tác</th>
                    <th class="text-center">Số kiện</th>
                    <th class="text-center">Cân nặng</th>
                    <th class="text-center">Số khối</th>
                    <th class="text-center">Ngày tạo</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr item-id="@Model[i].Id">
                        <td class="text-center"><input type="checkbox" class="waybillCheckbox" /></td>
                        <td>
                            @Model[i].Name
                        </td>
                        <td>@Model[i].Partner</td>
                        <td>@Model[i].Quantity</td>
                        <td>@Model[i].Weight</td>
                        <td>@Model[i].Volume</td>
                        <td>Ngày tạo: @Model[i].Created.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@Model[i].StatusName</td>
                        <td class="text-center">
                            <p>
                                <button class="btn btn-sm btn-primary" onclick="window.location.href='@Url.RouteUrl("big-package-detail", new { id = Model[i].Id })'">
                                    Chi tiết
                                </button>
                            </p>
                            @* @if (Model[i].Status == (int)EBigPackageStatus.New)
                        {
                        <p>
                        <button class="btn btn-sm btn-danger" onclick="deleteBigPackage(@Model[i].Id)">Hủy đơn</button>
                        </p>
                        } *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
