    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
        }

        .login-wrapper {
            display: flex;
            height: 100vh;
        }

        /* LEFT */
        .login-left {
            flex: 7;
            background: url('/tpkexpress/images/auth-background.jpg');
            position: relative;
        }



        /* RIGHT */
        .login-right {
            flex: 3;
            background: #fff;
            display: flex;
            align-items: start;
            justify-content: center;
            padding-top: 2rem;
        }

        .login-box {
            width: 90%;
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo {
            max-width: 160px;
            margin-bottom: 1rem;
        }

        .login-header h2 {
            font-size: 1.4rem;
            margin: 0;
        }

        .form-group {
            margin-bottom: 1.4rem;
        }

        .icon-input {
            position: relative;
        }

            .icon-input i {
                position: absolute;
                left: 4px;
                top: 50%;
                transform: translateY(-50%);
                color: #999;
                font-size: 14px;
            }

            .icon-input input {
                width: 100%;
                padding: 0.6rem 0.4rem 0.6rem 26px;
                border: none;
                border-bottom: 1px solid #ccc;
                font-size: 0.95rem;
            }

                .icon-input input:focus {
                    outline: none;
                    border-bottom-color: #ff6600;
                }

            .icon-input:focus-within i {
                color: #ff6600;
            }

        .remember {
            margin: 1rem 0;
            font-size: 0.9rem;
        }

        .btn-login {
            width: 100%;
            background: #f45b1e;
            color: #fff;
            border: none;
            padding: 0.65rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.95rem;
        }

            .btn-login:hover {
                background: #e04f18;
            }

        .login-links {
            display: flex;
            justify-content: space-between;
            margin-top: 1rem;
            font-size: 0.85rem;
        }

            .login-links a {
                color: #f45b1e;
                text-decoration: none;
            }
    </style>
</head>
<body>

    <div class="login-wrapper">

        <!-- LEFT -->
        <div class="login-left">
            <div class="overlay"></div>
        </div>

        <!-- RIGHT -->
        <div class="login-right">
            <div class="login-box">

                <div class="login-header">
                    <a href="/">
                        <img src="/images/logo.png" class="logo">
                    </a>
                    <h3>Đăng nhập</h3>
                </div>

                <div class="form-group icon-input">
                    <i class="fa fa-user"></i>
                    <input type="text" id="username" placeholder="Tài khoản">
                </div>

                <div class="form-group icon-input">
                    <i class="fa fa-lock"></i>
                    <input type="password" id="password" placeholder="Mật khẩu">
                </div>

                <button class="btn-login" onclick="signIn()">Đăng nhập</button>

                <div class="login-links">
                    <a href="/dang-ky">Đăng ký ngay !</a>
                    <a href="/quen-mat-khau">Quên mật khẩu ?</a>
                </div>

            </div>
        </div>

    </div>

</body>
