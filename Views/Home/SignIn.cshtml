<script src="/tpkexpress/assets/library/gsap/ScrollTrigger.min.js"></script>
<script src="/tpkexpress/js/main.js" type="module"></script>
<script>
    function signIn() {
        let userName = $('#username').val();
        if (userName.trim() === "") {
            showToast("Username là bắt buộc", 3, false);
            return;
        }
        let password = $('#password').val();
        if (password.trim() === "") {
            showToast("Password là bắt buộc", 3, false);
            return;
        }
        disableButton();
        // Gửi yêu cầu AJAX
        $.ajax({
            url: '/Home/SignIn', // URL tới action
            type: 'POST',
            data: { username: userName, password: password },
            success: function (response) {
                if (response.Data == 2) {
                    window.location.href = "/home";
                } else {
                    window.location.href = "/dashboard";
                }
            },
            error: function (response) {
                showToast(response.responseJSON.Message, response.responseJSON.Type, false);
            },
            complete: function () {
                enableButton();
            }
        });
    }
</script>
<script>
    function showToast(message, type, isReload) {
        let bgColor = "green";
        switch (type) {
            case 1:
                bgColor = "red"
                break;
            case 2:
                bgColor = "#ffc107"
                break;
            case 3:
                bgColor = "blue"
                break;
            default:
                bgColor = "green";
                break;
        }
        Toastify({
            text: message,
            duration: 3000,
            gravity: "top", // Vị trí top
            position: "right", // Hiển thị bên phải
            backgroundColor: bgColor,
        }).showToast();
        if (isReload) {
            setTimeout(
                function () {
                    window.location.reload();
                },
                1000
            );
        }
    }

    function disableButton() {
        // Chọn tất cả các button và link (a) trên trang
        const elements = document.querySelectorAll('button, a');

        elements.forEach(el => {
            // Thêm lớp 'disabled' để hiển thị trạng thái không hoạt động
            el.classList.add('disabled');

            // Disable nút nếu là button
            if (el.tagName.toLowerCase() === 'button') {
                el.disabled = true;
            }

            // Ngăn chặn hành động mặc định nếu là link (a)
            if (el.tagName.toLowerCase() === 'a') {
                el.addEventListener('click', function (event) {
                    event.preventDefault();
                });
            }
        });
    }

    function enableButton() {
        // Chọn tất cả các button và link (a) có lớp 'disabled'
        const elements = document.querySelectorAll('button, a');

        elements.forEach(el => {
            // Xóa lớp 'disabled' để khôi phục trạng thái hoạt động
            el.classList.remove('disabled');

            // Bật lại nút nếu là button
            if (el.tagName.toLowerCase() === 'button') {
                el.disabled = false;
            }

            // Loại bỏ sự kiện 'click' ngăn hành động mặc định nếu là link (a)
            if (el.tagName.toLowerCase() === 'a') {
                const newElement = el.cloneNode(true); // Tạo bản sao không có sự kiện
                el.replaceWith(newElement); // Thay thế thẻ hiện tại bằng bản sao
            }
        });
    }
</script>