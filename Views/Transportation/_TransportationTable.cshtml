@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Models.Responses
@using WebMVC.Ultilities
@using WebMVC.Ultilities.Enums
@inject IHttpContextService _httpContextService;
@model List<TransportationResponse>
@{
    var loggedModel = _httpContextService.GetLoggedModel();
}
<div id="table-container">
    <div class="table-content">
        <table class="table table-hover table-bordered">
            <thead class="table">
                <tr>
                    @if (loggedModel.IsStaff == 1)
                    {
                        <th class="text-center">#</th>
                        <th class="text-center">Mã vận đơn</th>
                    <th class="text-center">Username</th>
                    <th class="text-center">Mã bao</th>
                    <th class="text-center">Hình thức vận chuyển</th>
                    <th class="text-center">Cân nặng</th>
                    <th class="text-center">Số khối</th>
                    <th class="text-center">Số kiện</th>
                    <th class="text-center">Đơn giá cân</th>
                    <th class="text-center">Đơn giá khối</th>
                    <th class="text-center">Tổng tiền</th>
                    <th class="text-center">Phụ phí</th>
                    <th class="text-center">Ngày tạo</th>
                    <th class="text-center">Ngày về kho TQ</th>
                    <th class="text-center">Ngày về kho đích</th>
                    <th class="text-center">Ngày xuất kho</th>
                    <th class="text-center">Thông tin SP</th>
                    <th class="text-center">Voucher</th>
                    <th class="text-center">Trạng thái</th>
                    @*                         <th class="text-center">Ảnh</th>
 *@                    }
                        else
                    {
                        <th class="text-center">STT</th>
                        <th class="text-center">#</th>
                        <th class="text-center">Mã vận đơn</th>
                            <th class="text-center">Thông tin SP</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Cân nặng</th>
                            <th class="text-center">Số khối</th>
                            <th class="text-center">Số kiện</th>
                            <th class="text-center">Kho TQ</th>
                            <th class="text-center">Kho VN</th>
                            <th class="text-center">PTVC</th>
                            <th class="text-center">Phụ phí</th>
                            <th class="text-center">Ngày tạo</th>
                            <th class="text-center">Ngày XK</th>
                        }
                        <th class="text-center"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (loggedModel.IsStaff == 1)
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr item-id="@Model[i].Id">
                            @if ((loggedModel.RoleId == (int)ERoleId.Admin
                           || new[] { 6783, 6899, 9602, 25 }.Contains(loggedModel.Id))
                           && loggedModel.IsStaff == 1)
                            {
                                    <td class="text-center"><input type="checkbox" class="waybillCheckbox" /></td>
                                }
                                else
                                {
                                    <td class="text-center">@((ViewBag.CurrentPage - 1) * (ViewBag.PageSize) + i + 1)</td>
                                }
                                <td class="text-center">
                                    <span class="truncate-text">@Model[i].Barcode</span>
                                </td>
                                <td class="text-center">@Model[i].AccountName</td>
                                <td class="text-center">@Model[i].BigPackageName</td>
                                <td class="text-center">@Model[i].ShipName</td>
                                <td class="text-center">@Model[i].Weight</td>
                                <td class="text-center">@Model[i].Volume</td>
                                <td class="text-center">@Model[i].Quantity</td>
                                <td class="text-center">@string.Format("{0:N0}", Model[i].UnitWeight)</td>
                                <td class="text-center">@string.Format("{0:N0}", Model[i].UnitVolume)</td>
                                <td class="text-center">@string.Format("{0:N0}", Model[i].TotalPriceVND)</td>
                                <td class="text-center">@string.Format("{0:N0}", Model[i].SurchargeVND)</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].Created)</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].DateArrivedAtTQWarehouse)</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].DateArrivedAtVNWarehouse)</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].DateCompleted)</td>
                                <td class="text-center">
                                    <span data-bs-toggle="tooltip" data-bs-placement="top" title="@Model[i].UserNote">
                                        @(Model[i].UserNote?.Length > 20 ? Model[i].UserNote.Substring(0, 20) + "..." : Model[i].UserNote)
                                    </span>
                                </td>
                                <td class="text-center">@Model[i].VoucherInfo</td>
                                <td class="text-center">
                                    @Html.Raw(Model[i].StatusName)
                                 </td>
                                <td class="text-center">
                                    <p>
                                        <button class="btn btn-sm btn-primary" onclick="window.location.href='@Url.RouteUrl("transportation-detail", new { id = Model[i].Id })'">
                                            Chi tiết
                                        </button>
                                        @if (Model[i].ShipId == 5 && !string.IsNullOrEmpty(Model[i].UserUploadImage))
                                        {
                                            var fileName = System.IO.Path.GetFileName(Model[i].UserUploadImage);
                                            <a class="btn btn-sm btn-secondary" href="@Model[i].UserUploadImage" download="@fileName">
                                                Tải file
                                            </a>
                                        }
                                        else
                                        {
                                            @if (!string.IsNullOrEmpty(Model[i].Image))
                                            {
                                                <a class="btn btn-sm btn-secondary" target="_blank" href="@Model[i].Image">
                                                    Xem ảnh
                                                </a>
                                            }
                                        }
                                    </p>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr item-id="@Model[i].Id">
                                <td class="text-center">@((ViewBag.CurrentPage - 1) * (ViewBag.PageSize) + i + 1)</td>                               
                                <td class="text-center"><button class="btn btn-sm btn-primary" onclick="window.open('@Url.Action("Index", "Tracking", new { barcode = Model[i].Barcode })')"><i class="bi bi-eye"></i></button></td>
                                <td class="text-center">@Model[i].Barcode</td>
                                @* <td class="text-center">
                                    <span data-bs-toggle="tooltip" data-bs-placement="top" title="@Model[i].UserNote">
                                        @(Model[i].UserNote?.Length > 50 ? Model[i].UserNote.Substring(0, 50) + "..." : Model[i].UserNote)
                                    </span>
                                </td> *@
                                <td class="text-center" style="width: 250px;">
                                    <span data-bs-toggle="tooltip"
                                          title="@Model[i].UserNote"
                                          style="white-space: normal; word-break: break-word;">
                                        @Model[i].UserNote
                                    </span>
                                </td>
                                <td class="text-center">@Html.Raw(Model[i].StatusName)</td>
                                <td class="text-center">@Model[i].Weight</td>
                                <td class="text-center">@Model[i].Volume</td>
                                <td class="text-center">@Model[i].Quantity</td>
                                <td class="text-center">@Model[i].WarehouseFrom</td>
                                <td class="text-center">@Model[i].WarehouseTo</td>
                                <td class="text-center">@Model[i].ShipName</td>
                                <td class="text-center">@Model[i].Surcharge</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].Created)</td>
                                <td class="text-center">@FormatDate.FormatNullDate(Model[i].DateCompleted)</td>
                                <td class="text-center">
                                    @if (Model[i].AccountId == loggedModel.Id && Model[i].Status == (int)ETransportationStatus.New)
                                    {
                                        <button class="btn btn-sm btn-danger" onclick="deleteTransportation(@Model[i].Id)"><i class="bi bi-x-circle"></i></button>
                                    }
                                </td>
                            </tr>
                        }

                    }
                </tbody>
            </table>
        </div>
    @if (Model.Count > 0)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-end">

                @* Nút về đầu *@
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(1)">Đầu</a>
                    </li>
                }

                @{
                    int range = 4; // 👈 số trang mỗi bên
                    int startPage = Math.Max(1, ViewBag.CurrentPage - range);
                    int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + range);
                }

                @* Dấu ... phía trước *@
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Danh sách số trang *@
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@i)">@i</a>
                    </li>
                }

                @* Dấu ... phía sau *@
                @if (endPage < ViewBag.TotalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                @* Nút về cuối *@
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:void(0);" onclick="loadPage(@ViewBag.TotalPages)">Cuối</a>
                    </li>
                }

            </ul>
        </nav>
    }
</div>
    <style>
        .truncate-text {
            display: inline-block;
            width: 200px;
            white-space: normal !important;
            overflow: unset !important;
            text-overflow: unset !important;
        }

        .table > :not(caption) > * > * {
            padding: 4px !important;
        }
    </style>