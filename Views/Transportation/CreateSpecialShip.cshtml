@using WebMVC.Entities
@using WebMVC.Interfaces
@using WebMVC.Ultilities.Enums
@model List<Warehouse>
@inject IHttpContextService _httpContextService;
@{
    var loggedModel = await _httpContextService.GetCurrentAccount();
}
@{
    ViewData["Title"] = "Tạo đơn chính ngạch";
}

<div class="container-fluid mt-4">
    <div class="card mb-6">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="text-center ">Tạo đơn chính ngạch</h2>
        </div>
        <div class="card-body">
            <form id="orderForm" class="row">
                <div class="col-md-3">
                    <div class="row mb-3">
                        <div class="col-md-6 d-flex align-items-end">
                            <label for="warehouseFrom" class="form-label">Kho TQ</label>
                        </div>
                        <div class="col-md-6">
                            <select id="warehouseFrom" class="form-select" required>
                                <option value="">Chọn Kho TQ</option>
                                @foreach (var item in Model.Where(x => x.Type == (int)EWarehouseType.Reciever).ToList())
                                {
                                    <option value=@item.Id selected>@item.Name</option>
                                }
                            </select>
                            <div id="warehouseFromError" class="text-danger" style="display: none;">Vui lòng chọn Kho TQ</div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6 d-flex align-items-end">
                            <label for="warehouseTo" class="form-label">Kho VN</label>
                        </div>
                        <div class="col-md-6">
                            <select id="warehouseTo" class="form-select" required>
                                <option value="">Chọn Kho VN</option>
                                @foreach (var item in Model.Where(x => x.Type == (int)EWarehouseType.Destination).ToList())
                                {
                                    if (item.Id == loggedModel.ToWarehouseId)
                                    {
                                        <option value=@item.Id selected>@item.Name</option>
                                    }
                                    else
                                    {
                                        <option value=@item.Id>@item.Name</option>
                                    }
                                }
                            </select>
                            <div id="warehouseToError" class="text-danger" style="display: none;">Vui lòng chọn Kho VN</div>
                        </div>
                    </div>
                    <div class="row mb-3 d-none">
                        <div class="col-md-6 d-flex align-items-end">
                            <label for="transportMethod" class="form-label">Hình Thức Vận Chuyển</label>
                        </div>
                        <div class="col-md-6">
                            <select id="transportMethod" class="form-select" required disabled>
                                @{
                                    var shipType = Model.Where(x => x.Id == 5).FirstOrDefault();
                                    <option value=@shipType.Id selected>@shipType.Name</option>
                                }
                            </select>
                            <div id="transportMethodError" class="text-danger" style="display: none;">Vui lòng chọn Hình Thức Vận Chuyển</div>
                        </div>
                    </div>

                    <div class="text-end">
                        <a href="/templates/template-special.xlsx" download class="btn btn-outline-success"> File mẫu</a>
                        <button type="button" id="addItem" class="btn btn-primary "> Thêm Kiện</button>
                        <button type="button" id="createOrder" class="btn btn-success" disabled>Tạo Đơn Hàng</button>
                    </div>
                </div>
                <div class="col-md-9">
                    <div id="orderItems" class="mb-3">
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th style="width: 25%;">Mã Vận Đơn</th>
                                    <th style="width: 10%;">Số lượng SP</th>
                                    <th style="width: 10%;">Số cân</th>
                                    <th style="width: 10%;">Số khối</th>
                                    <th style="width: 25%;">Ghi Chú</th>
                                    <th style="width: 25%;">Voucher</th>
                                    <th style="width: 10%;">Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </form>
            <div>
                <p style="color:red; font-style:italic">Giải thích :</p>
                <p>(1) Mã Vận Đơn : là mã vận đơn giao hàng từ nhà máy đến kho của Trung Quốc của TPK</p>
                <p>(2) Số Lượng SP : Tổng số lượng sản phẩm trong một lô hàng , ví dụ : 100 sản phẩm A + 100 sản phẩm B = Tổng sản phẩm 200</p>
                <p>(3) Tên hàng : Tên sản phẩm khai báo để xuất hóa đơn</p>
                <p>(4) Số Lượng SP 1 : Số lượng của tên sản phẩm 1</p>
                <p>(5) Kích thước : kích thước của từng sản phẩm , không phải kích thước của kiện hàng</p>
                <p>(6) Công suất , điện áp, chất liệu :  sản phẩm là máy móc cần điền công suất điện áp , sản phẩm thông thường điền chất liệu</p>
                <p>(7) Quý khách tải file mẫu điền thông tin và tải file lên</p>
            </div>
        </div>
    </div>
</div>


<style>
    .table th {
        text-align: center;
    }

    /* Căn nút "Tạo Đơn Hàng" sang phải */
    .text-end {
        text-align: right;
    }
</style>
@section Scripts {
    <script>
        $(document).ready(function () {
            let selectedVouchers = [];
            let transportMethodId = "5";
            const legallyTransportMethodId = '5';
            function loadVouchers(selectElement) {
                $.ajax({
                    url: '/Voucher/GetVoucherAccount',
                    type: 'GET',
                    data: {},
                    success: function (response) {
                        if (response.Data) {
                            const vouchers = response.Data;
                            const $this = $(selectElement); // Tham chiếu đến dropdown đang được mở
                            const selectedVoucherId = $this.val(); // Lấy id của voucher đã được chọn

                            $this.empty();  // Xóa tất cả các option hiện tại
                            $this.append('<option value="">Chọn Voucher</option>');

                            // Duyệt qua tất cả các voucher và thêm vào dropdown
                            vouchers.forEach(function (voucher) {
                                const amount = voucher.Amount.toLocaleString('en-US');
                                const isSelected = selectedVouchers.includes(voucher.Id.toString()); // Kiểm tra voucher đã chọn

                                // Chỉ bỏ những voucher đã chọn khỏi danh sách
                                if (!isSelected) {
                                    $this.append(`<option value="${voucher.Id}">${voucher.Name} - ${amount} đ</option>`);
                                } else if (isSelected && voucher.Id.toString() === selectedVoucherId) {
                                    $this.append(`<option selected="selected" value="${voucher.Id}">${voucher.Name} - ${amount} đ</option>`);
                                }
                            });
                        }
                    },
                    error: function () {
                        showToast(response.responseJSON?.Message || "Lỗi không xác định", response.responseJSON?.Type || 2, false);
                    }
                });
            }

            function toggleCreateButton() {
                const hasItems = $("#orderItems .order-item").length > 0;
                $("#createOrder").prop("disabled", !hasItems);
            }

            $('#transportMethod').on('change', function () {
                const selectedId = $(this).val(); // ID hiện tại (kiểu chuỗi)

                const isOldLegal = transportMethodId == legallyTransportMethodId;
                const isNewLegal = selectedId == legallyTransportMethodId;

                // Cập nhật trạng thái mới
                transportMethodId = selectedId;
                // Nếu chuyển từ hoặc đến "5" (chính ngạch) thì reset + addItem
                if (isOldLegal !== isNewLegal) {
                    $('#orderItems tbody').empty();
                    $('#addItem').trigger('click');
                }
            });

            $("#addItem").on("click", function () {
                let itemHtml = `
                    <tr class="order-item-info">
                        <td><b>Thông tin đơn hàng</b></td>
                    </tr>
                    <tr class="order-item">
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control barcode" placeholder="Mã Vận Đơn" required>
                            </div>
                            <div class="text-danger barcode-error" style="display: none;">Mã Vận Đơn bị trùng!</div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="number" class="form-control userUploadQuantity" placeholder="Số lượng" value="1" min="1" required>
                            </div>
                        </td>
                        <td>
                            <input type="number" class="form-control userUploadWeight" placeholder="Cân nặng" value="0" min="0">
                        </td>
                        <td>
                            <input type="number" class="form-control userUploadVolume" placeholder="Số khối" value="0" min="0">
                        </td>
                        <td><input type="text" class="form-control note" placeholder="Ghi Chú"></td>
                        <td>
                            <select class="form-select voucher-select">
                                <option value="">Chọn Voucher</option>
                            </select>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-danger btn-remove-item">&#x2212;</button>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="7">
                            <span>Khai báo chi tiết</span>
                            <!--<button type="button" id="addProduct" class="btn btn-primary">Thêm sản phẩm</button>-->
                        </td>
                    </tr>
                    <tr class="order-item-user-upload">
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productName" placeholder="Tên hàng" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="number" class="form-control productQuantity" placeholder="Số lượng" value="1" min="1" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productDimensions" placeholder="Kích thước" required>
                            </div>
                        </td>
                        <td colspan="2">
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productOtherInfor" placeholder="Công suất điện áp, chất liệu" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*Tải file</span>
                                <input type="file" class="form-control productImage" required accept=".xlsx,.xls">
                            </div>
                        </td>
                        <td class="text-center"></td>
                    </tr>`;

                $("#orderItems tbody").prepend(itemHtml);
                toggleCreateButton();
            });

            // Gán sự kiện click cho nút addProduct
            $("#orderItems").on("click", "#addProduct", function () {
                const newProductRow = `
                    <tr class="order-item-user-upload">
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productName" placeholder="Tên hàng" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="number" class="form-control productQuantity" placeholder="Số lượng" value="1" min="1" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productDimensions" placeholder="Kích thước" required>
                            </div>
                        </td>
                        <td colspan="2">
                            <div class="d-flex align-items-center gap-1">
                                <span class="required-mark">*</span>
                                <input type="text" class="form-control productOtherInfor" placeholder="Công suất điện áp, chất liệu" required>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                        <span class="required-mark">*Tải file</span>
                                <input type="file" class="form-control productImage" required accept=".xlsx,.xls">
                            </div>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-danger btn-remove-product-item">&#x2212;</button>
                        </td>
                    </tr>`;

                $(this).closest('tr').after(newProductRow);
            });


            $("#orderItems").on("click", ".btn-remove-product-item", function () {
                $(this).closest("tr").remove();
            });

            $("#orderItems").on("click", ".btn-remove-item", function () {
                const orderRow = $(this).closest("tr.order-item");
                const orderInfoRow = orderRow.prev("tr.order-item-info");

                // Xử lý voucher nếu có
                const voucherId = orderRow.find(".voucher-select").val();
                if (voucherId) {
                    selectedVouchers = selectedVouchers.filter(function (id) {
                        return id !== voucherId;
                    });
                }

                // Xóa dòng chính và các dòng sản phẩm liên quan kế tiếp
                let $current = orderRow.next();

                while ($current.length && !$current.hasClass("order-item")) {
                    const $next = $current.next(); // lưu lại để tránh mất reference sau khi remove
                    $current.remove();
                    $current = $next;
                }

                // Xóa dòng chính cuối cùng
                orderRow.remove();
                orderInfoRow.remove();

                toggleCreateButton();
            });


            $("#createOrder").on("click", function () {
                const warehouseFrom = $("#warehouseFrom").val();
                const warehouseTo = $("#warehouseTo").val();
                const transportMethod = $("#transportMethod").val();

                let valid = validateSelectFields(warehouseFrom, warehouseTo, transportMethod);
                valid = validateBarcodes() && valid;
                valid = validateRequiredFields() && valid;

                if (!valid) return;

                if (!valid) return;

                const formData = new FormData();

                formData.append("WarehouseFrom", warehouseFrom);
                formData.append("WarehouseTo", warehouseTo);
                formData.append("TransportMethod", transportMethod);

                let itemIndex = 0;

                $("#orderItems .order-item").each(function () {
                    const $mainRow = $(this);
                    const barcode = $mainRow.find(".barcode").val()?.trim();
                    const note = $mainRow.find(".note").val()?.trim();
                    const voucherId = $mainRow.find(".voucher-select").val() || 0;

                    formData.append(`Items[${itemIndex}].Barcode`, barcode);
                    formData.append(`Items[${itemIndex}].Note`, note);
                    formData.append(`Items[${itemIndex}].VoucherId`, voucherId);

                    // Gắn thông tin UserUpload nếu có
                    const userUploadWeight = parseFloat($mainRow.find(".userUploadWeight").val()) || 0;
                    const userUploadVolume = parseFloat($mainRow.find(".userUploadVolume").val()) || 0;
                    const userUploadQuantity = parseInt($mainRow.find(".userUploadQuantity").val()) || 0;

                    if (userUploadWeight || userUploadVolume || userUploadQuantity) {
                        formData.append(`Items[${itemIndex}].UserUploadWeight`, userUploadWeight);
                        formData.append(`Items[${itemIndex}].UserUploadVolume`, userUploadVolume);
                        formData.append(`Items[${itemIndex}].UserUploadQuantity`, userUploadQuantity);
                    }

                    // Xử lý các dòng sản phẩm (Products)
                    let productIndex = 0;
                    let $current = $mainRow.next();

                    while ($current.length && !$current.hasClass("order-item")) {
                        if ($current.hasClass("order-item-user-upload")) {
                            const name = $current.find(".productName").val()?.trim();
                            const quantity = parseInt($current.find(".productQuantity").val()) || 0;
                            const dimensions = $current.find(".productDimensions").val()?.trim();
                            const otherInfor = $current.find(".productOtherInfor").val()?.trim();
                            const imageInput = $current.find(".productImage")[0];

                            formData.append(`Items[${itemIndex}].Products[${productIndex}].Name`, name);
                            formData.append(`Items[${itemIndex}].Products[${productIndex}].Quantity`, quantity);
                            formData.append(`Items[${itemIndex}].Products[${productIndex}].Dimensions`, dimensions);
                            formData.append(`Items[${itemIndex}].Products[${productIndex}].OtherInfor`, otherInfor);

                            if (imageInput?.files?.length > 0) {
                                formData.append(`Items[${itemIndex}].Products[${productIndex}].Image`, imageInput.files[0]);
                            }

                            productIndex++;
                        }

                        $current = $current.next();
                    }

                    itemIndex++;
                });

                disableButton();

                $.ajax({
                    url: "/Transportation/Create",
                    type: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        showToast(response.Message, response.Type, true);
                    },
                    error: function (response) {
                        showToast(response.responseJSON?.Message || "Đã xảy ra lỗi", response.responseJSON?.Type || "error", false);
                    },
                    complete: function () {
                        enableButton();
                    }
                });
            });


            $("#orderItems").on("mousedown", ".voucher-select", function () {
                loadVouchers($(this));
            });

            $("#orderItems").on("change", ".voucher-select", function () {
                const selectedVoucherId = $(this).val();
                const $this = $(this);

                // Lấy voucher cũ đã chọn trong dropdown
                const previousVoucherId = $this.data('previous-value');

                // Nếu có voucher cũ, loại bỏ nó khỏi selectedVouchers
                if (previousVoucherId && previousVoucherId !== selectedVoucherId) {
                    // Loại bỏ voucher cũ khỏi danh sách selectedVouchers
                    selectedVouchers = selectedVouchers.filter(function (id) {
                        return id !== previousVoucherId;
                    });
                }

                // Nếu có voucher mới được chọn, thêm vào selectedVouchers
                if (selectedVoucherId) {
                    selectedVouchers.push(selectedVoucherId);
                }

                // Lưu giá trị voucher mới vào data-attribute để so sánh lần sau
                $this.data('previous-value', selectedVoucherId);
            });
            function validateSelectFields(from, to, method) {
                let valid = true;

                if (!from) {
                    $("#warehouseFromError").show();
                    valid = false;
                } else {
                    $("#warehouseFromError").hide();
                }

                if (!to) {
                    $("#warehouseToError").show();
                    valid = false;
                } else {
                    $("#warehouseToError").hide();
                }

                if (!method) {
                    $("#transportMethodError").show();
                    valid = false;
                } else {
                    $("#transportMethodError").hide();
                }

                return valid;
            }

            function validateBarcodes() {
                const barcodes = [];
                let valid = true;

                $("#orderItems .order-item input.barcode").each(function () {
                    const barcode = $(this).val()?.trim();
                    const errorDiv = $(this).next(".barcode-error");

                    if (!barcode) {
                        errorDiv.text("Mã Vận Đơn không được để trống!").show();
                        valid = false;
                    } else if (barcodes.includes(barcode)) {
                        errorDiv.text("Mã Vận Đơn bị trùng!").show();
                        valid = false;
                    } else {
                        errorDiv.hide();
                        barcodes.push(barcode);
                    }
                });

                return valid;
            }

            function validateRequiredFields() {
                let valid = true;

                // Validate các input trong đơn chính
                $("#orderItems .order-item").each(function () {
                    const $item = $(this);
                    const quantity = $item.find(".userUploadQuantity");

                    [quantity].forEach(input => {
                        if (!input.val().trim()) {
                            input.addClass("is-invalid");
                            valid = false;
                        } else {
                            input.removeClass("is-invalid");
                        }
                    });
                });

                // Validate các sản phẩm trong từng kiện
                $(".order-item-user-upload").each(function () {
                    const $product = $(this);
                    const name = $product.find(".productName");
                    const quantity = $product.find(".productQuantity");
                    const dimensions = $product.find(".productDimensions");
                    const otherInfor = $product.find(".productOtherInfor");
                    const image = $product.find(".productImage");

                    [name, quantity, dimensions, otherInfor].forEach(input => {
                        if (!input.val().trim()) {
                            input.addClass("is-invalid");
                            valid = false;
                        } else {
                            input.removeClass("is-invalid");
                        }
                    });

                    if (!image[0].files.length) {
                        image.addClass("is-invalid");
                        valid = false;
                    } else {
                        image.removeClass("is-invalid");
                    }
                });

                return valid;
            }

            toggleCreateButton();
            $("#addItem").trigger("click");
        });
    </script>
    <style>
        .input-wrapper {
            position: relative;
            display: inline-block;
            width: 100%;
        }
    </style>
}